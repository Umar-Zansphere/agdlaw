# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender in Resend dashboard (domain or onboarding sender)
# Example: Anthony Law <no-reply@yourdomain.com>
RESEND_FROM_EMAIL=Anthony Law <no-reply@example.com>

# Where contact form submissions should be delivered
# If omitted, RESEND_FROM_EMAIL will be used as recipient.
CONTACT_TO_EMAIL=contact@example.com
